# Core LLM configuration
# Any OpenAI-compatible endpoint should work.
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://your-openai-compatible-endpoint/v1
LLM_MODEL_NAME=your_model_name_here

# Zep memory graph configuration
ZEP_API_KEY=your_zep_api_key_here

# Optional boost / secondary LLM configuration
LLM_BOOST_API_KEY=your_optional_boost_api_key_here
LLM_BOOST_BASE_URL=your_optional_boost_base_url_here
LLM_BOOST_MODEL_NAME=your_optional_boost_model_name_here

# Example: NVIDIA NIM
# LLM_API_KEY=nvapi-your_key_here
# LLM_BASE_URL=https://integrate.api.nvidia.com/v1
# LLM_MODEL_NAME=openai/gpt-oss-120b

# Model selector provider keys
NVIDIA_API_KEY=your_nvidia_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
KIMI_API_KEY=your_kimi_api_key_here
